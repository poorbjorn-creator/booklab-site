<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#1a1a2e;--bg2:#16213e;--bg3:#0f3460;--card:#222244;--gold:#e6a919;--cream:#f0e6d3;--text:#d4c5a9;--muted:#9a8c75;--radius:12px}
html{scroll-behavior:smooth;scroll-padding-top:70px}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.7;font-size:16px}
h1,h2,h3,h4{font-family:'Playfair Display',serif;color:var(--cream)}
a{color:var(--gold);text-decoration:none}
a:hover{text-decoration:underline}

nav{position:sticky;top:0;z-index:100;background:rgba(26,26,46,.97);backdrop-filter:blur(10px);border-bottom:1px solid rgba(230,169,25,.15);padding:0 20px}
.nav-inner{max-width:1400px;margin:0 auto;display:flex;align-items:center;gap:4px;height:54px}
.nav-inner a:not(.nav-brand){display:none}
.nav-brand{font-family:'Playfair Display',serif;color:var(--gold)!important;font-size:1rem;font-weight:700;margin-right:auto;flex-shrink:0}
.hamburger{display:flex;flex-direction:column;justify-content:center;gap:5px;background:none;border:none;cursor:pointer;padding:8px;z-index:201;margin-left:auto}
.hamburger span{display:block;width:24px;height:2.5px;background:var(--gold);border-radius:2px;transition:transform .3s,opacity .3s}
.hamburger.active span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}
.nav-overlay{position:fixed;top:0;right:-100%;width:280px;height:100%;background:rgba(26,26,46,.98);z-index:200;display:flex;flex-direction:column;padding:70px 30px 30px;gap:6px;transition:right .3s ease;box-shadow:-4px 0 20px rgba(0,0,0,.5);overflow-y:auto}
.nav-overlay.open{right:0}
.nav-overlay a{color:var(--muted);font-size:1rem;padding:12px 16px;border-radius:8px;text-decoration:none;font-weight:500;transition:.2s}
.nav-overlay a:hover,.nav-overlay a:focus{color:var(--gold);background:rgba(230,169,25,.1)}
.nav-overlay-bg{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:199}
.nav-overlay-bg.open{display:block}
body.nav-open{overflow:hidden}

footer{text-align:center;padding:50px 20px;border-top:1px solid rgba(230,169,25,.1);margin-top:40px;color:var(--muted);font-size:.85rem}
footer .links{margin-top:12px;display:flex;justify-content:center;gap:20px;flex-wrap:wrap}
footer .links a{color:var(--gold)}
</style>
<style>
.hero{text-align:center;padding:80px 20px 50px;background:linear-gradient(180deg,#0f0f23 0%,var(--bg) 100%)}
.hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:var(--gold);margin-bottom:12px;letter-spacing:-1px}
.hero .tagline{font-size:clamp(.95rem,2vw,1.2rem);color:var(--cream);font-family:'Playfair Display',serif;font-style:italic;max-width:700px;margin:0 auto 12px}
.hero .sub{font-size:.9rem;color:var(--muted);max-width:700px;margin:0 auto 30px;line-height:1.8}
.divider{width:60px;height:3px;background:var(--gold);margin:24px auto;border-radius:2px}

.container{max-width:900px;margin:0 auto;padding:0 20px}

.theme-.theme-nav a{font-size:.8rem;padding:6px 16px;border-radius:20px;border:1px solid rgba(230,169,25,.3);color:var(--muted);transition:.2s;font-weight:500}
.theme-nav a:hover{color:var(--gold);border-color:var(--gold);background:rgba(230,169,25,.08);text-decoration:none}

.theme-section{margin-bottom:50px}
.theme-section h2{font-size:clamp(1.3rem,3vw,1.8rem);color:var(--gold);text-align:left;margin-bottom:6px}
.theme-section .theme-desc{color:var(--muted);font-size:.88rem;margin-bottom:24px}

.book-card{background:var(--card);border-radius:var(--radius);padding:24px;display:flex;gap:20px;align-items:flex-start;margin-bottom:20px;border-left:3px solid var(--gold);transition:transform .2s,box-shadow .2s}
.book-card:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,0,0,.3)}
.book-card img{width:100px;min-width:100px;border-radius:6px;box-shadow:0 4px 15px rgba(0,0,0,.4);object-fit:cover}
.book-card .book-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:rgba(230,169,25,.2);line-height:1;margin-bottom:4px}
.book-card .book-title{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;color:var(--cream);margin-bottom:2px}
.book-card .book-author{color:var(--gold);font-size:.85rem;margin-bottom:8px}
.book-card .book-desc{font-size:.9rem;line-height:1.7}
.book-card .book-tag{display:inline-block;font-size:.7rem;padding:3px 10px;border-radius:12px;background:rgba(230,169,25,.1);color:var(--gold);margin-top:10px;font-weight:500}

.video-cta{text-align:center;padding:50px 20px;margin:20px 0}
.video-cta .btn{display:inline-block;font-weight:600;font-size:.95rem;padding:14px 32px;border-radius:8px;background:var(--gold);color:#1a1a2e;transition:.2s}
.video-cta .btn:hover{background:#d4990f;text-decoration:none;transform:scale(1.03)}

@media(max-width:600px){
  .hero{padding:60px 16px 40px}
  .book-card{flex-direction:column;padding:18px}
  .book-card img{width:80px;min-width:80px}
}
</style>
</head>
